		"check": "npm run typecheck && npm run build && wrangler deploy --dry-run",
		"deploy": "npm run build && wrangler deploy",
		"dev": "react-router dev",
		"preview": "npm run build && vite preview",
		"typegen": "wrangler types && react-router typegen",
		"typecheck": "npm run typegen && tsc -b",
		"copy-wasm": "node scripts/copy-wasm.mjs",
		"predev": "npm run copy-wasm",
		"prebuild": "npm run copy-wasm"
	},
	"type": "module"
