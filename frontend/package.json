		"isbot": "5.1.32",
		"lucide-react": "^1.17.0",
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"react-router": "7.16.0",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "1.39.0",
		"@cloudflare/workers-types": "4.20260530.1",
		"@react-router/dev": "7.16.0",
		"@tailwindcss/vite": "4.1.17",
		"@types/node": "24.10.1",
