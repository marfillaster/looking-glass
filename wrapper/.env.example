# --- looking-glass wrapper config (copy to .env; all values have safe defaults) ---

# Bind address. KEEP THIS ON LOOPBACK in production — cloudflared reaches the
# wrapper over 127.0.0.1 and the box exposes no inbound ports. Loopback binding
# is the wrapper's only local security boundary (there is no client auth), so a
# non-loopback address is REFUSED at startup unless LG_UNSAFE_NON_LOOPBACK=1.
LG_LISTEN_ADDR=127.0.0.1:8080

# Intentionally-unsafe escape hatch: allow a non-loopback bind for dev/staging
# reached over a trusted overlay (e.g. WireGuard). NEVER set in production.
LG_UNSAFE_NON_LOOPBACK=

# Routing daemon for BGP queries: frr (vtysh, default) or bird (birdc). Only the
# BGP path differs; ping/traceroute are daemon-agnostic. The BIRD backend uses
# the restricted read-only client `birdc -r` and translates queries into BIRD's
# filter language (path masks for as-path, community pairs for community).
LG_ROUTING_BACKEND=frr

# Binaries. Bare names are resolved via PATH; set absolute paths for a minimal
# container image. Only the one for the selected backend is used.
LG_VTYSH_PATH=vtysh
LG_BIRDC_PATH=birdc
LG_PING_PATH=ping
LG_TRACEROUTE_PATH=traceroute

# BIRD routing-table names per family (bird backend only). BIRD splits v4/v6 into
# separate tables; the BGP query selects the one matching the resolved family.
LG_BIRD_TABLE_V4=master4
LG_BIRD_TABLE_V6=master6

# Optional source addresses for ping/traceroute. Pair this with source-based
# policy routing on the router when probes should egress a specific path.
LG_PROBE_SOURCE_IPV4=
LG_PROBE_SOURCE_IPV6=

# Address-family policy for BGP and probes. Use ipv6 for IPv6-only ASes, ipv4
# for IPv4-only, or ipv4,ipv6 / dual for dual stack.
LG_ADDRESS_FAMILIES=ipv4,ipv6

# Optional: restrict the BGP query enum further (comma list of: prefix,as-path,community).
# Empty = all allowed.
LG_ALLOW_QUERY_TYPES=

# Bounds (clamped internally). Seconds for *_SEC.
LG_BGP_TIMEOUT_SEC=10
LG_PING_COUNT=5
LG_PING_TIMEOUT_SEC=15
LG_TRACEROUTE_MAX_HOPS=15
LG_TRACEROUTE_QUERIES=2
LG_TRACEROUTE_TIMEOUT_SEC=20
